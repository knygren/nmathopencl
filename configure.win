#!/bin/sh

echo "🛠 [configure.win] Starting OpenCL detection"
echo "Shell = $SHELL"
echo "Initial PATH = $PATH"

# --------------------------------------------------------------------
# 1. Load system PATH entries
# --------------------------------------------------------------------
# On Windows, the PATH seen by msys2/bash may differ from the MACHINE-
# level PATH where SDKs (CUDA, Intel, AMD) register themselves.
# PowerShell reliably retrieves the MACHINE PATH, so we prefer it.
# If PowerShell is unavailable, fall back to the msys2 PATH.
# --------------------------------------------------------------------

if command -v powershell.exe >/dev/null 2>&1; then
  echo "🔍 Loading MACHINE Path with PowerShell"
  IFS=';' read -ra SYSTEM_PATHS <<< "$(
    powershell.exe -NoProfile -Command "[System.Environment]::GetEnvironmentVariable('Path','Machine')"
  )"
else
  echo "⚠️  powershell.exe not found, falling back to msys2 \$PATH"
  IFS=':' read -ra SYSTEM_PATHS <<< "$PATH"
fi

# Initialize search paths with system PATH entries
SEARCH_PATHS+=("${SYSTEM_PATHS[@]}")

echo "🔍 Current SEARCH_PATHS:"
for p in "${SEARCH_PATHS[@]}"; do
  echo "   - $p"
done

# --------------------------------------------------------------------
# 2. Add user-defined environment variables (OPENCL_HOME, OPENCL_SDK)
# --------------------------------------------------------------------
# These allow advanced users to explicitly point to an OpenCL SDK.
# We check the root, root/include, and root/include/CL.
# --------------------------------------------------------------------

for var in OPENCL_HOME OPENCL_SDK; do
  val="${!var}"
  if [ -n "$val" ]; then
    echo "🔧 Found $var=$val"
    for sub in "" "/include" "/include/CL"; do
      path="$val$sub"
      if [ -d "$path" ]; then
        echo "✅ Adding $path from $var"
        SEARCH_PATHS+=("$path")
      else
        echo "❌ Skipping $path — not found"
      fi
    done
  fi
done

echo "🔍 Current SEARCH_PATHS:"
for p in "${SEARCH_PATHS[@]}"; do
  echo "   - $p"
done

# --------------------------------------------------------------------
# 3. Detect known OpenCL SDK installations
# --------------------------------------------------------------------
# These are common installation roots for:
#   - NVIDIA CUDA Toolkit
#   - Intel OpenCL SDK (legacy)
#   - AMD APP SDK (legacy)
#   - Intel oneAPI Toolkit
# --------------------------------------------------------------------

declare -A SDK_LABELS=(
  ["C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA"]="NVIDIA CUDA Toolkit"
  ["C:/Program Files (x86)/IntelSWTools/OpenCL SDK"]="Intel OpenCL SDK"
  ["C:/Program Files (x86)/AMD APP SDK"]="AMD APP SDK"
  ["C:/Program Files (x86)/Intel/oneAPI"]="Intel oneAPI Toolkit"
)

echo "🔎 Checking for known OpenCL SDK installations..."
for root in "${!SDK_LABELS[@]}"; do
  if [ -d "$root" ]; then
    echo "✅ Found ${SDK_LABELS[$root]} at: $root"
    SEARCH_PATHS+=("$root" "$root/include" "$root/include/CL")
  else
    echo "❌ ${SDK_LABELS[$root]} not found at: $root"
  fi
done

echo "🔍 Current SEARCH_PATHS:"
for p in "${SEARCH_PATHS[@]}"; do
  echo "   - $p"
done

# --------------------------------------------------------------------
# 4. Dynamically scan CUDA versioned folders
# --------------------------------------------------------------------
# CUDA installs multiple versioned directories (v11.8, v12.2, etc.).
# Each may contain its own OpenCL headers under include/CL.
# --------------------------------------------------------------------

CUDA_ROOT="C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA"
if [ -d "$CUDA_ROOT" ]; then
  for subdir in "$CUDA_ROOT"/v*; do
    if [ -d "$subdir/include/CL" ]; then
      echo "🔍 Found CUDA subdir: $subdir"
      SEARCH_PATHS+=("$subdir/include" "$subdir/include/CL")
    fi
  done
fi

echo "🔍 Current SEARCH_PATHS:"
for p in "${SEARCH_PATHS[@]}"; do
  echo "   - $p"
done

# --------------------------------------------------------------------
# 5. Add fallback static paths
# --------------------------------------------------------------------
# These are optional but useful for:
#   - manually installed SDKs
#   - portable OpenCL SDKs
#   - custom developer setups
# --------------------------------------------------------------------

STATIC_PATHS=(
  "C:/OpenCL-SDK"
  "C:/opt"
  "C:/Program Files (x86)"
)

for path in "${STATIC_PATHS[@]}"; do
  if [ -d "$path" ]; then
    echo "📦 Adding static path: $path"
    SEARCH_PATHS+=("$path")
  else
    echo "❌ Static path not found: $path"
  fi
done

echo "🔍 Current SEARCH_PATHS:"
for p in "${SEARCH_PATHS[@]}"; do
  echo "   - $p"
done

echo "🔍 Combined SEARCH_PATHS (n=${#SEARCH_PATHS[@]}): ${SEARCH_PATHS[*]}"

# --------------------------------------------------------------------
# 6. Search for cl.h
# --------------------------------------------------------------------
# We look for:
#     <path>\CL\cl.h
# This is the canonical OpenCL header location across:
#   - CUDA Toolkit
#   - Intel OpenCL SDK
#   - AMD APP SDK
#   - oneAPI
#   - custom installs
# --------------------------------------------------------------------

CL_HEADER=""
for dir in "${SEARCH_PATHS[@]}"; do
  if [ -f "$dir\CL\cl.h" ]; then
    CL_HEADER="$dir\CL\cl.h"
    break
  fi
done

echo "🔎 CL_HEADER = $CL_HEADER"

# --------------------------------------------------------------------
# 6b. Rcpp include — not part of OpenCL SEARCH_PATHS; R finds LinkingTo Rcpp via .libPaths().
# If several libraries contain Rcpp, tools/rcpp_include.R picks the newest (or GLMBAYES_RCPP_LIB).
# Emitting PKG_CPPFLAGS puts -I.../Rcpp/include before other flags so g++ prefers that tree.
# --------------------------------------------------------------------
RSCRIPT=""
if [ -n "${R_HOME:-}" ] && [ -x "${R_HOME}/bin/Rscript" ]; then
  RSCRIPT="${R_HOME}/bin/Rscript"
elif [ -n "${R_HOME:-}" ] && [ -n "${R_ARCH:-}" ] && [ -x "${R_HOME}/bin${R_ARCH}/Rscript" ]; then
  RSCRIPT="${R_HOME}/bin${R_ARCH}/Rscript"
else
  RSCRIPT=$(command -v Rscript 2>/dev/null || true)
fi
if [ -z "$RSCRIPT" ]; then
  echo "configure.win: cannot find Rscript (set R_HOME)" >&2
  exit 1
fi
echo "🔧 Resolving Rcpp include via: $RSCRIPT"
# tools/rcpp_include.R prints: line1 = VERSION<TAB>LIB, line2 = -I"path/to/Rcpp/include"
RCPP_OUT=$("$RSCRIPT" --vanilla tools/rcpp_include.R) || exit $?
RCPP_META=$(printf '%s\n' "$RCPP_OUT" | head -n 1)
RCPP_CPPFLAGS=$(printf '%s\n' "$RCPP_OUT" | tail -n 1)
RCPP_PKG_VERSION=$(printf '%s\n' "$RCPP_META" | cut -f1)
RCPP_PKG_LIB=$(printf '%s\n' "$RCPP_META" | cut -f2)
R_ID_LINE=$("$RSCRIPT" -e 'rv <- as.character(getRversion()); v <- R.version; s <- if (!is.null(v[["svn.rev"]])) v[["svn.rev"]] else v[["svn rev"]]; s <- as.character(s); if (!length(s) || !nzchar(s)) s <- "unknown"; cat(sprintf("configure.win: R version: %s (svn: %s)", rv, s))')
echo "$R_ID_LINE"
echo "configure.win: confirmed Rcpp package version ${RCPP_PKG_VERSION} (library: ${RCPP_PKG_LIB})"
echo "📦 RCPP_CPPFLAGS = $RCPP_CPPFLAGS"

# R CMD INSTALL may not pass GLMBAYES_RCPP_LIB into this script; patch the same lib we use for -I
# (R 4.5.x / R-devel: Rcpp/Function.h can reference R_NamespaceRegistry when R no longer exposes it).
GLMBAYES_RCPP_LIB="$RCPP_PKG_LIB" "$RSCRIPT" --vanilla tools/patch_rcpp_function_h.R

# --------------------------------------------------------------------
# 7. Generate Makevars.win
# --------------------------------------------------------------------
# If cl.h is found:
#   - enable USE_OPENCL
#   - add include and lib paths
#   - link against OpenCL.lib
#
# If not found:
#   - fall back to CPU-only build
# --------------------------------------------------------------------


if [ -n "$CL_HEADER" ]; then
  CL_BASE=$(dirname "$CL_HEADER")
  INCLUDE_FLAG="-I\"$CL_BASE\""
  LIB_FLAG="-L\"$CL_BASE\\..\\..\\lib\\x64\""

  OPEN_CL_HOME=$(echo "$CL_BASE" | sed 's:[/\\]include[/\\]CL$::')
  OPEN_CL_HOME=$(echo "$OPEN_CL_HOME" | sed 's:\\:/:g')

  INCLUDE_FLAG="-I\"$OPEN_CL_HOME/include\""
  LIB_FLAG="-L\"$OPEN_CL_HOME/lib/x64\""

  echo "⚙️  INCLUDE_FLAG = $INCLUDE_FLAG"
  echo "⚙️  LIB_FLAG     = $LIB_FLAG"

  # CRAN-safe, OpenMP-free, quoting-stable
  MAKEVARS_CONTENT="PKG_CPPFLAGS = $RCPP_CPPFLAGS
PKG_CXXFLAGS = -DGLMBAYES_BUILD -DUSE_OPENCL $INCLUDE_FLAG
PKG_LIBS = $LIB_FLAG -lOpenCL \$(LAPACK_LIBS) \$(BLAS_LIBS) \$(FLIBS)"
else
  # CPU-only fallback, also CRAN-safe
  MAKEVARS_CONTENT="PKG_CPPFLAGS = $RCPP_CPPFLAGS
PKG_CXXFLAGS = -DGLMBAYES_BUILD
PKG_LIBS = \$(LAPACK_LIBS) \$(BLAS_LIBS) \$(FLIBS)"
fi

echo "📦 MAKEVARS_CONTENT:"
echo "$MAKEVARS_CONTENT"

# Write Makevars.win
echo "$MAKEVARS_CONTENT" > src/Makevars.win